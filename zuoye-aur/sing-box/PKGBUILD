# Maintainer: yidaduizuoye <yidaduizuoye at outlook dot com>

pkgname=sing-box
pkgver=1.13.7
pkgrel=1
pkgdesc='The universal proxy platform.'
arch=('x86_64')
url='https://sing-box.sagernet.org/'
license=('custom:GPL-3.0-or-later WITH name use or association addition')
depends=('glibc' 'dbus' 'polkit')
makedepends=('clang' 'git' 'go' 'lld')
source=("git+https://github.com/SagerNet/sing-box.git#tag=v$pkgver")
sha256sums=('205c0439c9e9462b29f8f9cadab3ffd7738a72cd4fac5d5d534eccd6d1bbd0fc')
provides=("$pkgname")
conflicts=("$pkgname")
backup=("etc/$pkgname/config.json")

build() {
    cd "$pkgname"
    local tags=$(cat release/DEFAULT_BUILD_TAGS)
    local _ldflags=$(cat release/LDFLAGS)
    local ldflags=(
        "-s"
        "-w"
        "-linkmode=external"
        "-X github.com/sagernet/sing-box/constant.Version=$pkgver"
        "$_ldflags"
    )

    export GOFLAGS="-buildmode=pie -trimpath -mod=readonly -modcacherw"
    export CGO_CPPFLAGS="${CPPFLAGS}"
    export CGO_CFLAGS="${CFLAGS}"
    export CGO_CXXFLAGS="${CXXFLAGS}"
    export CGO_LDFLAGS="${LDFLAGS} -fuse-ld=lld"
    export CGO_ENABLED=1
    export CC=clang
    export CXX=clang++

    go build \
        -v \
        -tags "$tags" \
        -ldflags "${ldflags[*]}" \
        ./cmd/sing-box
}

package() {
    cd "$pkgname"
    install -Dvm644 LICENSE -t "$pkgdir/usr/share/licenses/$pkgname"
    install -Dvm755 "$pkgname" -t "$pkgdir/usr/bin"
    install -Dvm644 "release/config/config.json" -t "$pkgdir/etc/$pkgname"
    install -Dvm644 "release/config/$pkgname.service" -t "$pkgdir/usr/lib/systemd/system"
    install -Dvm644 "release/config/$pkgname@.service" -t "$pkgdir/usr/lib/systemd/system"
    install -Dvm644 "release/config/$pkgname.sysusers" "$pkgdir/usr/lib/sysusers.d/$pkgname.conf"
    install -Dvm644 "release/config/$pkgname.rules" -t "$pkgdir/usr/share/polkit-1/rules.d"
    install -Dvm644 "release/config/$pkgname-split-dns.xml" "$pkgdir/usr/share/dbus-1/system.d/$pkgname.conf"

    "$pkgdir/usr/bin/$pkgname" completion bash | 
        install -Dvm644 /dev/stdin "$pkgdir/usr/share/bash-completion/completions/$pkgname"
    "$pkgdir/usr/bin/$pkgname" completion zsh | 
        install -Dm644 /dev/stdin "$pkgdir/usr/share/zsh/site-functions/_$pkgname"
    "$pkgdir/usr/bin/$pkgname" completion fish | 
        install -Dm644 /dev/stdin "$pkgdir/usr/share/fish/vendor_completions.d/$pkgname.fish"
}
