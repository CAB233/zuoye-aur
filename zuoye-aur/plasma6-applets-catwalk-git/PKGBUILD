# Maintainer: yidaduizuoye <yidaduizuoye at outlook dot com>

pkgname=plasma6-applets-catwalk-git
pkgver=r12.eded6e7
pkgrel=1
pkgdesc="Simple plasmoid showing the total CPU usage. Visually made like RunCat."
url="https://invent.kde.org/heddxh/applet-catwalk"
arch=('x86_64')
license=("GPL-2.0-or-later")
depends=(
    'ksvg'
    'libksysguard'
    'libplasma'
    'qt6-declarative'
    'kcmutils'
    'kirigami'
)
makedepends=(
    'cmake'
    'extra-cmake-modules'
    'git'
    'ki18n'
    'ninja'
)
source=("git+${url}.git")
sha256sums=('SKIP')

pkgver() {
    cd applet-catwalk
    printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short=7 HEAD)"
}

build() (
    cmake -G Ninja -B build -S applet-catwalk \
        -DCMAKE_INSTALL_PREFIX=/usr \
        -DCMAKE_BUILD_TYPE=Release
    cmake --build build
)

package() (
    DESTDIR="$pkgdir" cmake --install build
)
